{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "vinext-boilerplate-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-01",
  "compatibility_flags": ["nodejs_compat_v2"],
  "routes": [
    { "pattern": "vinext-api.peto.dev", "custom_domain": true }
  ],
  "dev": {
    "port": 8787
  }
}
